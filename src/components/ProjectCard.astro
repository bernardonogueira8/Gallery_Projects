---
const { title, image, objectives, link, type } = Astro.props;
---

<div class="card bg-base-200 shadow-xl border border-white/10 hover:border-success/50 transition-all duration-300">
  <a target="_blank" href={link} class="relative"> 
    <span class="badge badge-soft badge-success absolute top-4 right-4 z-10 badge-sm">
      {type}
    </span>

    <figure class="px-2 pt-2">
      <img src={image} alt={title} class="rounded-xl aspect-video object-cover image-full" />
    </figure>

    <div class="card-body p-4">
      <h1 class="card-title text-sm font-bold uppercase tracking-widest">{title}</h1>
      <div class="mt-2">
        <p class="text-xs font-semibold text-gray-400">Objetivos principais e indicadores:</p>
        <p class="text-sm line-clamp-3">{objectives}</p>
      </div>
    </div>
  </a>
</div>
